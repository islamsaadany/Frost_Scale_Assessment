# ── Database (PostgreSQL) ────────────────────────────────────────────
# Pooled connection used at runtime.
DATABASE_URL="postgresql://user:password@localhost:5432/frost_scale?schema=public"
# Direct (unpooled) connection used for migrations / `prisma db push`.
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/frost_scale?schema=public"

# ── Auth (admin) ─────────────────────────────────────────────────────
# Secret used to sign admin session cookies (next-auth).
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# ── Seed admin (used by prisma/seed.ts) ──────────────────────────────
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me"
SEED_ADMIN_NAME="مسؤول النظام"
