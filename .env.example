# ── Database (PostgreSQL) ────────────────────────────────────────────
# Pooled connection used at runtime.
DATABASE_URL="postgresql://user:password@localhost:5432/frost_scale?schema=public"
# Direct (unpooled) connection used for migrations / `prisma db push`.
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/frost_scale?schema=public"

# ── Auth (admin) ─────────────────────────────────────────────────────
# Secret used to sign admin session cookies (next-auth).
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# ── Seed admin (used by prisma/seed.ts) ──────────────────────────────
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me"
SEED_ADMIN_NAME="مسؤول النظام"

# ── Email (Resend) — for emailing the report PDF ─────────────────────
# Sign up at resend.com, verify a sending domain, create an API key.
RESEND_API_KEY=""
# Verified sender, e.g. "مقياس فروست <no-reply@yourdomain>"
EMAIL_FROM=""

# ── Local PDF rendering (dev only) ───────────────────────────────────
# Path to a local Chrome/Chromium for the PDF export in development.
# On Vercel this is ignored (@sparticuz/chromium is used automatically).
# LOCAL_CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
